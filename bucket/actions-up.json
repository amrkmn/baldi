{
    "version": "1.14.0",
    "description": "Interactive CLI tool to update GitHub Actions to latest versions with SHA pinning",
    "homepage": "https://github.com/azat-io/actions-up",
    "license": "MIT",
    "url": "https://registry.npmjs.org/actions-up/-/actions-up-1.14.0.tgz",
    "hash": "sha512:9102416ff229a8c6973305761bb0b94f4fe1d3a362ad8667fc06e9c8df532eb0f90422fa484eb1f3ea260cc2aeb3d197098b1b3741b383bc02dd780883721677",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "actions-up",
            "$dir\\bin\\actions-up.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
        "url": "https://registry.npmjs.org/actions-up/latest",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://registry.npmjs.org/actions-up/-/actions-up-$version.tgz",
        "hash": {
            "url": "https://registry.npmjs.org/actions-up/$version",
            "regex": "sha512-([A-Za-z0-9+/=]+)"
        }
    }
}
