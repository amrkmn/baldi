{
    "version": "1028",
    "description": "Jellium Desktop (nightly.link)",
    "homepage": "https://github.com/andrewrabert/jellium-desktop",
    "license": "GPL-2.0-only",
    "architecture": {
        "64bit": {
            "url": "https://nightly.link/andrewrabert/jellium-desktop/actions/artifacts/8422838152.zip",
            "hash": "5b3a8ac3d3c3d8e482679d929af670600abe8f5c4c79fe92b83cb7e2a2ee8a4a"
        },
        "arm64": {
            "url": "https://nightly.link/andrewrabert/jellium-desktop/actions/artifacts/8422859458.zip",
            "hash": "7f991361024f461cb524c050d7665cbf0cb291c67a496c67b097506677e1543a"
        }
    },
    "pre_install": [
        "$inner = Get-ChildItem \"$dir\\JelliumDesktop-*.zip\" | Select-Object -First 1",
        "if ($inner) { Expand-Archive $inner.FullName -DestinationPath \"$dir\" -Force; Remove-Item $inner.FullName -Force }"
    ],
    "bin": "jellium-desktop.exe",
    "shortcuts": [
        [
            "jellium-desktop.exe",
            "Jellium Desktop"
        ]
    ],
    "checkver": {
        "script": [
            "$headers = @{ 'Accept' = 'application/vnd.github+json' }; if ($env:GITHUB_TOKEN) { $headers['Authorization'] = \"Bearer $env:GITHUB_TOKEN\" }",
            "$r = Invoke-RestMethod 'https://api.github.com/repos/andrewrabert/jellium-desktop/actions/workflows/build-windows.yml/runs?per_page=1&status=completed&branch=main' -Headers $headers",
            "$run = $r.workflow_runs[0]",
            "$artifacts = Invoke-RestMethod $run.artifacts_url -Headers $headers",
            "$x64 = ($artifacts.artifacts | Where-Object { $_.name -eq 'windows-x64' }).id",
            "$arm64 = ($artifacts.artifacts | Where-Object { $_.name -eq 'windows-arm64' }).id",
            "Write-Output \"$($run.run_number)-$x64-$arm64\""
        ],
        "regex": "(?<version>\\d+)-(?<x64id>\\d+)-(?<arm64id>\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nightly.link/andrewrabert/jellium-desktop/actions/artifacts/$matchX64id.zip",
                "hash": {
                    "mode": "json",
                    "url": "https://api.github.com/repos/andrewrabert/jellium-desktop/actions/artifacts/$matchX64id",
                    "jp": "$.digest"
                }
            },
            "arm64": {
                "url": "https://nightly.link/andrewrabert/jellium-desktop/actions/artifacts/$matchArm64id.zip",
                "hash": {
                    "mode": "json",
                    "url": "https://api.github.com/repos/andrewrabert/jellium-desktop/actions/artifacts/$matchArm64id",
                    "jp": "$.digest"
                }
            }
        }
    }
}
