{
    "version": "1000",
    "description": "Jellyfin Desktop Client (nightly.link)",
    "homepage": "https://github.com/jellyfin/jellyfin-desktop",
    "license": "GPL-2.0-only",
    "architecture": {
        "64bit": {
            "url": "https://nightly.link/jellyfin/jellyfin-desktop/actions/artifacts/8281245319.zip",
            "hash": "a7bd10d3c7073c8bcc770cf3832e1d0d5a04a0ebcce7b6a1eb2ae33b4a3f604b"
        },
        "arm64": {
            "url": "https://nightly.link/jellyfin/jellyfin-desktop/actions/artifacts/8281354279.zip",
            "hash": "26e767f924782ab223bb5985aa8ef27cf033972351bdd8e1cb0e36e321aa4b13"
        }
    },
    "pre_install": [
        "$inner = Get-ChildItem \"$dir\\JellyfinDesktop-*.zip\" | Select-Object -First 1",
        "if ($inner) { Expand-Archive $inner.FullName -DestinationPath \"$dir\" -Force; Remove-Item $inner.FullName -Force }"
    ],
    "bin": "jellyfin-desktop.exe",
    "shortcuts": [
        [
            "jellyfin-desktop.exe",
            "Jellyfin Desktop"
        ]
    ],
    "checkver": {
        "script": [
            "$headers = @{ 'Accept' = 'application/vnd.github+json' }; if ($env:GITHUB_TOKEN) { $headers['Authorization'] = \"Bearer $env:GITHUB_TOKEN\" }",
            "$r = Invoke-RestMethod 'https://api.github.com/repos/jellyfin/jellyfin-desktop/actions/workflows/build-windows.yml/runs?per_page=1&status=completed&branch=main' -Headers $headers",
            "$run = $r.workflow_runs[0]",
            "$artifacts = Invoke-RestMethod $run.artifacts_url -Headers $headers",
            "$x64 = ($artifacts.artifacts | Where-Object { $_.name -eq 'windows-x64' }).id",
            "$arm64 = ($artifacts.artifacts | Where-Object { $_.name -eq 'windows-arm64' }).id",
            "Write-Output \"$($run.run_number)-$x64-$arm64\""
        ],
        "regex": "(?<version>\\d+)-(?<x64id>\\d+)-(?<arm64id>\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nightly.link/jellyfin/jellyfin-desktop/actions/artifacts/$matchX64id.zip",
                "hash": {
                    "mode": "json",
                    "url": "https://api.github.com/repos/jellyfin/jellyfin-desktop/actions/artifacts/$matchX64id",
                    "jp": "$.digest"
                }
            },
            "arm64": {
                "url": "https://nightly.link/jellyfin/jellyfin-desktop/actions/artifacts/$matchArm64id.zip",
                "hash": {
                    "mode": "json",
                    "url": "https://api.github.com/repos/jellyfin/jellyfin-desktop/actions/artifacts/$matchArm64id",
                    "jp": "$.digest"
                }
            }
        }
    }
}
