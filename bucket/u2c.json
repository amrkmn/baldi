{
    "version": "2026.06.13.90639de",
    "description": "CLI uploader for Copyparty servers",
    "homepage": "https://github.com/9001/copyparty",
    "license": "MIT",
    "depends": "python",
    "url": "https://raw.githubusercontent.com/9001/copyparty/90639de9840d7dcc2d9000026fe547f666c1d550/bin/u2c.py",
    "hash": "0edb78dc96396aad93f7f8d89d6f392d378cac4a11d6b54395347017493d0c90",
    "bin": [
        [
            "python",
            "u2c",
            "$dir\\u2c.py"
        ]
    ],
    "checkver": {
        "script": [
            "$c = (Invoke-RestMethod 'https://api.github.com/repos/9001/copyparty/commits?path=bin/u2c.py&per_page=1')[0]",
            "$date = $c.commit.author.date.ToString('yyyy.MM.dd')",
            "$sha = $c.sha.Substring(0,7)",
            "Write-Output \"$date.$sha|$($c.sha)\""
        ],
        "regex": "^(?<version>\\d{4}\\.\\d{2}\\.\\d{2}\\.[a-f0-9]{7})\\|(?<commit>[a-f0-9]+)$"
    },
    "autoupdate": {
        "url": "https://raw.githubusercontent.com/9001/copyparty/$matchCommit/bin/u2c.py"
    }
}
