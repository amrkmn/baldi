{
    "version": "0.33.0",
    "description": "An open-source AI agent that brings the power of Gemini directly into your terminal",
    "homepage": "https://google-gemini.github.io/gemini-cli/",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@google/gemini-cli/-/gemini-cli-0.33.0.tgz",
    "hash": "sha512:6887185214fe76060e557f7e2505511ded38e7ecf4c506881eb05dbc04e455e5f2c45c709ebbde6628f2353127935424a66ceef9f774c7eb8e7cfc2ea1d0b835",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "gemini",
            "$dir\\dist\\index.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
        "url": "https://registry.npmjs.org/@google/gemini-cli/latest",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://registry.npmjs.org/@google/gemini-cli/-/gemini-cli-$version.tgz",
        "hash": {
            "url": "https://registry.npmjs.org/@google/gemini-cli/$version",
            "regex": "sha512-([A-Za-z0-9+/=]+)"
        }
    }
}
