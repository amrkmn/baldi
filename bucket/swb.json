            "hash": "9514f7f8ccf0ac2759375238269f8d3acb448d4d80548c88684680a7395e49e1"
        }
    },
    "pre_install": [
        "$hasAVX2 = Start-Job -ScriptBlock { Add-Type -MemberDefinition '[DllImport(\"kernel32.dll\")] public static extern bool IsProcessorFeaturePresent(int ProcessorFeature);' -Name Kernel32 -Namespace Win32; [Win32.Kernel32]::IsProcessorFeaturePresent(40) } | Receive-Job -Wait -AutoRemoveJob",
        "$folder = if (-not $hasAVX2) { \"swb-windows-x64-baseline\" } else { \"swb-windows-x64\" }",
        "Move-Item \"$dir\\$folder\\*\" \"$dir\" -Force",
        "Remove-Item \"$dir\\swb-v*\" -Recurse -Force"
    ],
    "bin": "swb.exe",
    "checkver": {
        "url": "https://github.com/amrkmn/swb/releases/latest/download/latest.json",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": [
                    "https://github.com/amrkmn/swb/releases/download/v$version/swb-windows-x64.zip",
                    "https://github.com/amrkmn/swb/releases/download/v$version/swb-windows-x64-baseline.zip"
                ]
            },
            "arm64": {
                "url": "https://github.com/amrkmn/swb/releases/download/v$version/swb-windows-arm64.zip"
            }
        },
        "hash": {
            "mode": "json",
            "url": "https://github.com/amrkmn/swb/releases/latest/download/latest.json",
            "jp": "$.releases.['$basename'].hash"
        }
    }
}
