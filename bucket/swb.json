                "https://github.com/amrkmn/swb/releases/download/v0.7.8/swb-windows-x64-baseline.zip"
            ],
            "hash": [
                "8ce7181b0ff20850b87145ef0071c444c664e1aaeaf4b2278ef94346e90db279",
                "092f0237a7102e5940bda1397cb07dbef6638dc680388562f1fcc9b9b4080f80"
