{
    "version": "0.15.2",
    "description": "Qwen Code is a coding agent that lives in digital world",
    "homepage": "https://github.com/QwenLM/qwen-code",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.15.2.tgz",
    "hash": "sha512:97178ff18f79c5a00644adb431824440c3c47bba4124b5064291db9d6cabf7dcce8b7a10eda5d271f0100771043f52c7ab34ec492729c348af200512bb59753e",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
