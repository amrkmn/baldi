    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.13.2.tgz",
    "hash": "sha512:9a0b9f0cafdc45674cee96f84554bdfb065b94ac7658311e1acc62fc38ed5472b38a5edcfd0ab2ad3ac9f5fb3b84b767e6d99bb71277a6ef870067c98360d415",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
