{
    "version": "0.12.6",
    "description": "Qwen Code is a coding agent that lives in digital world",
    "homepage": "https://github.com/QwenLM/qwen-code",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.12.6.tgz",
    "hash": "sha512:de205624802e3a8b66c1e79c81d44e05e20c329168f8b04a20ed0039560ba6e9f9bd2c249ff0936530ebf2af56d315b2513f2a0a68386076b5da0f7038dc0230",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
