    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.15.5.tgz",
    "hash": "sha512:f32f10ba6a8d50ad7f644826fe23abde1d5033a8b05c892a2cd3fefe1e12a7ffd7615f605053fdf0edc6dc9ee01b1448e381a70563b675e27bfaa69ac93e5c92",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
