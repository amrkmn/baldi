    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.15.9.tgz",
    "hash": "sha512:0c47d659beb2a78d798fd2333879a0443131b9d063d7d62eb558db338da8ba4836cc91a22c12cfda2a713b1f682a4de8da4d901a6740db20801582ea835e1cdf",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
