{
    "version": "0.19.0",
    "description": "Qwen Code is a coding agent that lives in digital world",
    "homepage": "https://github.com/QwenLM/qwen-code",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.19.0.tgz",
    "hash": "sha512:37399ddc0a2d01f20b457d38a27ceb955ad4046d4a85290840d4919ebfa423a4b9bd1db2df34e15eb803410bc1d22096a75ba7baf6c80d715a3086e1fb89c021",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
