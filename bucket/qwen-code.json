    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.19.8.tgz",
    "hash": "sha512:5f986360e130305fdb1880af0f0ab125aa813043b0a5683028ca0f46dc2afe4f28f69af199a329638cc1b6cae132c17608d941eba140d6f334b01bcd98dbc9d1",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
