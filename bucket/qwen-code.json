    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.19.4.tgz",
    "hash": "sha512:0ecd29a2f4adccadbec0c3616aa926704e8cf684d3fb20764e6d0d20b3eca7b0ef46c7e7231aac03533e79b8d944d422ec38a091b6b8eb19425e40bd1bbc02e9",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "qwen",
