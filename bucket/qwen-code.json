{
    "version": "0.14.2",
    "description": "Qwen Code is a coding agent that lives in digital world",
    "homepage": "https://github.com/QwenLM/qwen-code",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.14.2.tgz",
    "hash": "sha512:66d1d16520d229fb98b95e51df413ee0d41a172e1a1874160b178153698729e86eb72d735ec9f320c8058dc0dc6942e20ab1c965ee9c50436512991cf4177bf7",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
