{
    "version": "0.18.1",
    "description": "Qwen Code is a coding agent that lives in digital world",
    "homepage": "https://github.com/QwenLM/qwen-code",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.18.1.tgz",
    "hash": "sha512:4090379e69bd4e6cff72f8865ddb707daafed7ef386d10d1ff6e1f8572baa126047b081066862e099469c481cc88ca0e3e22c32a651d3cdf2ae03a8e50e32bb7",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
