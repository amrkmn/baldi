{
    "version": "0.10.6",
    "description": "Qwen Code is a coding agent that lives in digital world",
    "homepage": "https://github.com/QwenLM/qwen-code",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.10.6.tgz",
    "hash": "sha512:5c7126d25d25f5d7cd4f94d68598ec961388fafef8a85de734aca83d2dafa7414b5f6e62274a053ef8e783ee4ef688151df62adafa43b124a7c121c18cdfe992",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
        "url": "https://registry.npmjs.org/@qwen-code/qwen-code/latest",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-$version.tgz",
        "hash": {
            "url": "https://registry.npmjs.org/@qwen-code/qwen-code/$version",
            "regex": "sha512-([A-Za-z0-9+/=]+)"
        }
    }
}
