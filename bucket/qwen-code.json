    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.13.1.tgz",
    "hash": "sha512:720a8df230da3718262244baad62f0619d5bac8f3537aa728583f20a4c2ba5accee6f691d1916e00d53880050b1cdd8feeb3f0a439b3be430b42ac9af07fdfb9",
    "extract_dir": "package",
