    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.15.7.tgz",
    "hash": "sha512:b6d103ee85e95dd1c406fb834f9d8aaac0f14f34857a051e082d4501e23bc7e2bd0bae06b1cf0f8ab2e0583ed5fa2b3e49f3c179c3c3502579e8626ae0294ba8",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
