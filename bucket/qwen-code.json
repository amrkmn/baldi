{
    "version": "0.19.12",
    "description": "Qwen Code is a coding agent that lives in digital world",
    "homepage": "https://github.com/QwenLM/qwen-code",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.19.12.tgz",
    "hash": "sha512:af5dff2cae863ad00014e739d8ea6d9625f190d17fd9f3748627e80bcd8110b75c22d92398ecc46654c343bb4b11ff17100bda8bf2cf1de3d842826a0a1115d1",
    "extract_dir": "package",
    "depends": "main/nodejs",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
