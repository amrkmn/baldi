    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.12.5.tgz",
    "hash": "sha512:2301513c403bae4078fccb1b0847a9f2b870fb070b3d2e53b2e24b7182f6fc867685878435380b88914f68e82f25eac76b66c6665ea9ea6c787d8486f0b8984f",
    "extract_dir": "package",
