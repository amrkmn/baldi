{
    "version": "0.12.3",
    "description": "Qwen Code is a coding agent that lives in digital world",
    "homepage": "https://github.com/QwenLM/qwen-code",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.12.3.tgz",
    "hash": "sha512:7fc1c45872243d5c4ab211f1e123fc6453ddfb396c76c6da28f6d78f0cf0368e05a6b9b51764f814af916ba5f8124dfb5994e390edd91cf9127c580d9507aa7b",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
