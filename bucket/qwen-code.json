{
    "version": "0.20.1",
    "description": "Qwen Code is a coding agent that lives in digital world",
    "homepage": "https://github.com/QwenLM/qwen-code",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.20.1.tgz",
    "hash": "sha512:28a08ec14c3ebbab3d3555c1712cceb671ef5ab1621eee1f04f956934eba6463a511ddb1db7ababb47fb8c8ab937b3e5b10b9160a14fb6b55cdb544b6dfd2fa4",
    "extract_dir": "package",
    "depends": "main/nodejs",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
        "url": "https://registry.npmjs.org/@qwen-code/qwen-code/latest",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-$version.tgz",
        "hash": {
            "url": "https://registry.npmjs.org/@qwen-code/qwen-code/$version",
            "regex": "sha512-([A-Za-z0-9+/=]+)"
        }
    }
}
