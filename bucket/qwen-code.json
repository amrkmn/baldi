{
    "version": "0.21.0",
    "description": "Qwen Code is a coding agent that lives in digital world",
    "homepage": "https://github.com/QwenLM/qwen-code",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.21.0.tgz",
    "hash": "sha512:878b7c72b1f5593292e08deea25390193cef1aeee25bd0eea887a06aafaff324574f24e4355ee4ef80004473d6621e4324bd5963f6420ec3ae3ec36168b967a2",
    "extract_dir": "package",
    "depends": "main/nodejs",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
        "url": "https://registry.npmjs.org/@qwen-code/qwen-code/latest",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-$version.tgz",
        "hash": {
            "url": "https://registry.npmjs.org/@qwen-code/qwen-code/$version",
            "regex": "sha512-([A-Za-z0-9+/=]+)"
        }
    }
}
