    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.19.6.tgz",
    "hash": "sha512:dd63e80329277a3af0fef3fd83091aebce522958e330400e4ead8e070c91861530ba6b932decbd7b55c98cb2477ea907b3f4fe95579ab56d855154de3ff5404d",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
