    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.19.5.tgz",
    "hash": "sha512:94984b9bd9d98b326a2fb15d8b419352e0b81efc4088abeb4f477e09ea256179d785dba912e05f5dd1c4e026df2927349c914e2fe71facacef5ecfcaa120c628",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
