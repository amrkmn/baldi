    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.19.1.tgz",
    "hash": "sha512:6cbed219763454042bbb221cb0031265921fcc9341ea0daeaf1e6aa5f41884ae714276f0939291da0e57aa28b74179a5937b2a4f6ee6b1e5c47c4490ba411fbb",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
