    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.18.4.tgz",
    "hash": "sha512:fff23fabb6de5cfde75113d90f39e335c7a6c408b04bec22b0d2cbdc78008769ef3edf0633282f3f0186569d6ec813e9484f91eec22f07eb92ea495fb135cd68",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
