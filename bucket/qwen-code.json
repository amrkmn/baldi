    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.15.1.tgz",
    "hash": "sha512:e8429f4a9cb4b09be41f21132e582bd3d0f096e693151618ead7700fd9e05a8a3d9cae6777272987d63ac8ffc9d29e452955bc6c4d6b4612c2be454ed6bf7eb6",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "qwen",
