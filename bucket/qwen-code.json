{
    "version": "0.17.0",
    "description": "Qwen Code is a coding agent that lives in digital world",
    "homepage": "https://github.com/QwenLM/qwen-code",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.17.0.tgz",
    "hash": "sha512:6c42c0380c05e6d93f8a0a93e9995b40e17435965974ffed92302794968781edb272ccfa0cd099e34dd234a91de7b871c8c4d9913f8964dcd4a390513a5ae31c",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
