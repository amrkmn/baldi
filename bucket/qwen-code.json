    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.19.3.tgz",
    "hash": "sha512:b62547afd3a2ddebc7b2058ae9c97aa492c50693f0363cdcb889cc968fcca6cab9f7ff05d51a58f69f37649b286e08a92cdc0c7a2f2f30f6ac52bf163d4bd7c7",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
