{
    "version": "0.20.0",
    "description": "Qwen Code is a coding agent that lives in digital world",
    "homepage": "https://github.com/QwenLM/qwen-code",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-0.20.0.tgz",
    "hash": "sha512:0e6ec0e5e9dc927da9cd791ab902794ad29564468877c95bc4d2b993fb17c89ba68855698bf63ff17fa7b486c139c307f502306991407f8b67b8fc13f6f9ce16",
    "extract_dir": "package",
    "depends": "main/nodejs",
    "bin": [
        [
            "node",
            "qwen",
            "$dir\\cli.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
        "url": "https://registry.npmjs.org/@qwen-code/qwen-code/latest",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://registry.npmjs.org/@qwen-code/qwen-code/-/qwen-code-$version.tgz",
        "hash": {
            "url": "https://registry.npmjs.org/@qwen-code/qwen-code/$version",
            "regex": "sha512-([A-Za-z0-9+/=]+)"
        }
    }
}
