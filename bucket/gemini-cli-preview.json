{
    "version": "0.46.0-preview.1",
    "description": "An open-source AI agent that brings the power of Gemini directly into your terminal (Preview)",
    "homepage": "https://google-gemini.github.io/gemini-cli/",
    "license": "Apache-2.0",
    "url": "https://registry.npmjs.org/@google/gemini-cli/-/gemini-cli-0.46.0-preview.1.tgz",
    "hash": "sha512:9d88652c1c16f6d583a33118782a00c0509914c595310539ea67e1fff0e160d9f3094710cafe260b0a778feaef809dd523f2488364f480cbc2f67bc4d253dcad",
    "extract_dir": "package",
    "depends": "main/nodejs-lts",
    "bin": [
        [
            "node",
            "gemini",
            "$dir\\bundle\\gemini.js"
        ]
    ],
    "post_install": [
        "Push-Location $dir",
        "npm install --omit=dev --silent",
        "Pop-Location"
    ],
    "checkver": {
        "url": "https://registry.npmjs.org/@google/gemini-cli/preview",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://registry.npmjs.org/@google/gemini-cli/-/gemini-cli-$version.tgz",
        "hash": {
            "url": "https://registry.npmjs.org/@google/gemini-cli/$version",
            "regex": "sha512-([A-Za-z0-9+/=]+)"
        }
    }
}
